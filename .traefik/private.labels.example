# label_file format: key=value
# use literal hostnames here; Docker Compose does not interpolate ${...} in this file
traefik.http.routers.local-pipe-test.rule=Host(`test.local-pipe.example.com`)
traefik.http.routers.local-pipe-test.entrypoints=websecure
traefik.http.routers.local-pipe-test.tls=true
traefik.http.routers.local-pipe-test.tls.certresolver=letsencrypt
traefik.http.routers.local-pipe-test.service=local-pipe

traefik.http.routers.local-pipe-api-preview.rule=Host(`api-preview.local-pipe.example.com`)
traefik.http.routers.local-pipe-api-preview.entrypoints=websecure
traefik.http.routers.local-pipe-api-preview.tls=true
traefik.http.routers.local-pipe-api-preview.tls.certresolver=letsencrypt
traefik.http.routers.local-pipe-api-preview.service=local-pipe

traefik.http.routers.local-pipe-stripe.rule=Host(`stripe.local-pipe.example.com`)
traefik.http.routers.local-pipe-stripe.entrypoints=websecure
traefik.http.routers.local-pipe-stripe.tls=true
traefik.http.routers.local-pipe-stripe.tls.certresolver=letsencrypt
traefik.http.routers.local-pipe-stripe.service=local-pipe
