LOCAL_PIPE_UID=10001
LOCAL_PIPE_GID=10001
PORT=8030
ADMIN_HOST=local-pipe.example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-this
ADMIN_RATE_LIMIT_MAX=60
ADMIN_RATE_LIMIT_WINDOW_MS=60000
LOG_HEALTHCHECKS=false
ALLOWED_TARGET_HOSTS=127.0.0.1,localhost
MAX_ROUTES=250
# Optional default SSH target for quick access. Just used as a placeholder in the UI
DEFAULT_SSH_TARGET=tunnel@example-vps
# Optional local-only Docker Compose override for private Traefik routers:
# COMPOSE_FILE=compose.yml:.traefik/compose.private.yml
# Compose interpolates the same .env values into both files.
# Backend host Traefik should use for the host-networked local-pipe service.
# On Linux with custom Docker bridge networks, host.docker.internal may point to
# the wrong gateway. If dashboard requests return 504, set this to the Traefik
# container's actual bridge gateway, for example:
# docker inspect -f '{{range .NetworkSettings.Networks}}{{.Gateway}}{{end}}' traefik
TRAEFIK_BACKEND_HOST=host.docker.internal
# Default bind host for SSH reverse forwards. With host networking on the VPS,
# 127.0.0.1 is the simplest and most reliable default.
DEFAULT_REMOTE_BIND_HOST=127.0.0.1
DEFAULT_LOCAL_HOST=127.0.0.1
